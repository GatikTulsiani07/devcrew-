{
  "name": "devcrew",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=.env.local --import tsx --watch src/server.ts",
    "build": "tsc -p tsconfig.server.json",
    "start": "node --env-file-if-exists=.env.local dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts",
    "lint": "eslint",
    "db:generate": "node --env-file-if-exists=.env.local node_modules/drizzle-kit/bin.cjs generate",
    "db:check": "node --env-file-if-exists=.env.local node_modules/drizzle-kit/bin.cjs check"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.30",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "typescript-eslint": "^8.64.0"
  }
}
